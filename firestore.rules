rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Vishwaas Guard Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a strict User-Ownership model. Most data is private and nested
     * under the user's specific profile path. This structure ensures that users can only access
     * and manage their own data while simplifying the authorization logic.
     *
     * DATA STRUCTURE:
     * - /userProfiles/{userId}: The root document for a user.
     * - /userProfiles/{userId}/deepfakeDetectionEvents/{eventId}: Private records of detection events.
     * - /userProfiles/{userId}/userReports/{reportId}: Private records of reports filed by the user.
     * - /scamSignatures/{signatureId}: Global, read-only data used for identification patterns.
     *
     * KEY SECURITY DECISIONS:
     * 1. Authorization Independence: Critical fields like 'userId' are denormalized onto child 
     *    documents. This allows rules to verify ownership by comparing the auth UID, the path 
     *    wildcard, and the internal document data without expensive get() calls.
     * 2. Structural Segregation: Public detection patterns (ScamSignatures) are separated from 
     *    private user data to prevent accidental exposure and simplify list operations.
     * 3. Prototyping Flexibility: While ownership is strictly enforced, data types and specific
     *    object schemas are not validated to allow for rapid frontend development and iteration.
     * 4. Immutable Identity: Relational fields (like userId) are enforced as immutable during 
     *    updates to prevent a document from being "re-assigned" to a different user.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the provided ID matches the authenticated user's UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * Checks if the user is the owner and the document exists. 
     * Used for update and delete operations. 
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile collection. Users can only see and manage their own profile.
     * @path /userProfiles/{userId}
     * @allow (get, create) Authenticated user with UID matching the {userId} wildcard.
     * @deny (list) Requests for documents where the UID does not match the wildcard.
     * @principle Enforces path-based ownership and self-creation.
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Records of deepfake detection analysis linked to a specific user.
       * @path /userProfiles/{userId}/deepfakeDetectionEvents/{eventId}
       * @allow (list, create) User querying or adding to their own subcollection.
       * @deny (create) Mismatched internal userId field compared to the path wildcard.
       * @principle Authorization independence via internal field validation.
       */
      match /deepfakeDetectionEvents/{eventId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Reports submitted by users regarding suspicious activities.
       * @path /userProfiles/{userId}/userReports/{reportId}
       * @allow (get, list, create) User managing their own incident reports.
       * @deny (update) Attempting to change the userId field of an existing report.
       * @principle Structural segregation of private user data.
       */
      match /userReports/{reportId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Global characteristics and patterns for identifying scams.
     * @path /scamSignatures/{signatureId}
     * @allow (get, list) All users, including unauthenticated users, to facilitate detection logic.
     * @deny (create, update, delete) Any client-side write operations.
     * @principle Public read access for shared utility data; administrative control for writes.
     */
    match /scamSignatures/{signatureId} {
      allow get, list: if true;
      allow create, update, delete: if false; // Managed by backend service/administrator
    }

  }
}