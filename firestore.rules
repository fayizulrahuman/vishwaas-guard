rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VISHWAAS GUARD SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model combined with role-based access control 
     * for administrative tasks. It prioritizes Authorization Independence by using denormalized 
     * UIDs and path-based wildcards, minimizing the need for expensive cross-document lookups.
     *
     * Data Structure:
     * - /users/{userId}: Private profile data, owned by the authenticated user.
     * - /users/{userId}/deepfakeAlerts: User-specific alerts, owned by the user.
     * - /users/{userId}/userReports: Reports submitted by the user, owned by the user.
     * - /scamSignatures: Global reference patterns, readable by all users, writable by admins.
     * - /adminRoles: A registry of UIDs with administrative privileges.
     *
     * Key Security Decisions:
     * - Denormalization: The `userId` is stored inside alerts and reports to allow for 
     *   fast, independent authorization checks without parent lookups.
     * - DBAC (Database Access Control): Admin permissions are managed via document existence 
     *   in the /adminRoles collection rather than custom claims.
     * - Resource-Specific Roles: Global data (scam signatures) allows authenticated reads 
     *   for real-time detection while locking down modifications to verified admins.
     */

    /**
     * @description Rules for the UserProfile collection. Users can only manage their own profile.
     * @path /users/{userId}
     * @allow (get, list, create, update, delete) if the auth UID matches the userId wildcard.
     * @deny (any) if the auth UID does not match the userId wildcard or if unauthenticated.
     * @principle Enforces path-based ownership and validates internal ID consistency.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description DeepfakeAlerts nested under a user. Denormalized userId ensures independence.
       * @path /users/{userId}/deepfakeAlerts/{alertId}
       * @allow (create) if user owns the path and sets the userId field correctly.
       * @deny (update) if attempting to change the ownership field (userId).
       * @principle Authorization Independence via denormalized ownership fields.
       */
      match /deepfakeAlerts/{alertId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description UserReports nested under a user. 
       * @path /users/{userId}/userReports/{reportId}
       * @allow (list) if the owner is viewing their own report history.
       * @deny (create) if the report's internal userId doesn't match the path.
       * @principle Ensures relational integrity between the path and the document content.
       */
      match /userReports/{reportId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Global ScamSignature collection. Essential for detection logic.
     * @path /scamSignatures/{signatureId}
     * @allow (get, list) for any signed-in user.
     * @allow (create, update, delete) restricted to accounts in the adminRoles collection.
     * @principle Public authenticated reads with restricted administrative writes.
     */
    match /scamSignatures/{signatureId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if resource != null && isAdmin();
    }

    /**
     * @description Registry for administrative users.
     * @path /adminRoles/{adminId}
     * @allow (get) to check role status.
     * @deny (list, write) for standard users. Writes are typically handled via console or cloud functions.
     * @principle Existence-based role management (DBAC).
     */
    match /adminRoles/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; // System/Console managed for security
    }

    // --- Helper Functions ---

    /** Checks if the user is authenticated with Firebase. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if a document exists and the current user is the owner. Used for safe updates/deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Checks if the current user has a document in the adminRoles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid));
    }
  }
}